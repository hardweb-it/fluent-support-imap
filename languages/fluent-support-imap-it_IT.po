#: fluent-support-imap.php
msgid "%s requires Fluent Support to be active."
msgstr "%s richiede che Fluent Support sia attivo."

#: fluent-support-imap.php
msgid "IMAP Fetcher"
msgstr "IMAP Fetcher"

#: fluent-support-imap.php
msgid "Fetch emails via IMAP every few minutes — alternative to email piping"
msgstr "Recupera le email via IMAP ogni pochi minuti — alternativa al piping"

#: fluent-support-imap.php
msgid "<strong>Warning:</strong> The PHP IMAP extension is not installed on the server. Contact your hosting provider to enable it."
msgstr "<strong>Attenzione:</strong> L'estensione PHP IMAP non è installata sul server. Contatta il tuo hosting per abilitarla."

